{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "outDir": "./dist/node",
        "rootDir": ".",
        "declaration": false,
        "resolveJsonModule": true,
        "sourceMap": true
    },
    "include": [
        "server/**/*.ts",
        "electron/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "src",
        "dist"
    ]
}
