{
  "name": "ai-assistant",
  "version": "1.0.0",
  "description": "Local AI Assistant with iMessage",
  "main": "dist/node/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n srv,ui -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:electron": "npm run build:node && concurrently -k -n srv,ui,el -c blue,green,yellow \"node dist/node/server/index.js\" \"vite\" \"sleep 3 && electron .\"",
    "build:renderer": "vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:node",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "fastify": "^5.3.3",
    "@fastify/static": "^8.1.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/node": "^22.14.1",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "tsx": "^4.19.4",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.2"
  },
  "build": {
    "appId": "com.local.ai-assistant",
    "productName": "AI Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "config.json"
    ],

    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.icns"
    },

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Assistant"
    },

    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}
