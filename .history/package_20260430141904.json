{
  "name": "ai-assistant",
  "version": "1.0.0",
  "main": "dist/node/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n srv,ui -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:electron": "npm run build:node && concurrently -k -n srv,ui,el -c blue,green,yellow \"node dist/node/server/index.js\" \"vite\" \"sleep 3 && electron .\"",
    "build": "npm run build:renderer && npm run build:node",
    "build:renderer": "vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "fastify": "^5.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  },
  "build": {
    "appId": "com.local.ai-assistant",
    "productName": "AI Assistant",

    "directories": {
        "output": "dist-build"
    },

    "files": [
        "dist/**/*",
        "config.json",
        "package.json"
    ],

    "mac": {
        "target": ["dmg", "zip"],
        "category": "public.app-category.productivity"
    },

    "win": {
        "target": "nsis",
        "icon": "build/icon.ico"
    }
    }
}
